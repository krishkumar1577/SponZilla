# Backend Environment Variables Example

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/sponzilla

# Security
# Replace with a long, random string
JWT_SECRET=your_jwt_secret_here
SENTRY_DSN=

# Email & Notifications
# If RESEND_API_KEY is not set or is a placeholder starting with 're_your_api_key', the email service will fall back to Mock (Console Log) Mode
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="SponZilla <onboarding@resend.dev>"
SUPPORT_EMAIL=Sponzilla.k@gmail.com

# AI Services
# Get your key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Social Authentication (Google & GitHub OAuth)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Deployment URLs
BACKEND_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173
# Render sets RENDER_EXTERNAL_URL automatically; keep-alive pings /health every 14 min
# Set ENABLE_KEEP_ALIVE=false to disable
ENABLE_KEEP_ALIVE=true
